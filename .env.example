# EUR/USD AI Trading Agent — environment variables
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ─────────────────────────────────────────────────


# ── Anthropic (required) ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."


# ── News providers ─────────────────────────────────────────────────────────────
# At least one is required. All three gives best coverage.

# NewsAPI — https://newsapi.org/ (free tier: 100 requests/day)
NEWS_API_KEY=""

# AlphaVantage — https://www.alphavantage.co/ (free tier available)
# Used for both news sentiment and price data
ALPHA_VANTAGE_API_KEY=""

# EODHD — https://eodhd.com/ (paid, optional but recommended)
EODHD_API_KEY=""


# ── Slack (required for Slack notifications and bot commands) ──────────────────
# See README.md → "Set up a Slack app" for step-by-step instructions.

# Bot User OAuth Token — from OAuth & Permissions page (starts with xoxb-)
SLACK_BOT_TOKEN="xoxb-..."

# App-Level Token — from Basic Information → App-Level Tokens (starts with xapp-)
# Required for Socket Mode (two-way bot commands)
SLACK_APP_TOKEN="xapp-..."

# Incoming Webhook URL — from Incoming Webhooks page
# Used for one-way signal alerts (Job 1 and Job 2 notifications)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."


# ── Email notifications (optional) ────────────────────────────────────────────
# Only needed if you add "email" to NOTIFICATION_CHANNELS in config.py.
# For Gmail, use an App Password (not your main password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
